#!/usr/bin/env node
'use strict'

const fs = require('fs')
const path = require('path')
const readline = require('readline')
const { execSync } = require('child_process')
const os = require('os')

// ── Constants ────────────────────────────────────────────────────────
const WEB_BASE = process.env.SKILLBOSS_WEB_BASE || 'https://www.skillboss.co'
// Credential locations
const GLOBAL_CONFIG_DIR = path.join(os.homedir(), '.config', 'skillboss')
const GLOBAL_CREDS_PATH = path.join(GLOBAL_CONFIG_DIR, 'credentials.json')
const LOCAL_CONFIG_PATH = path.join(__dirname, '..', 'config.json')

// ── Terminal helpers ─────────────────────────────────────────────────
const hasColor = process.stderr.isTTY && !process.env.NO_COLOR

const c = {
  green:  s => hasColor ? `\x1b[32m${s}\x1b[0m` : s,
  red:    s => hasColor ? `\x1b[31m${s}\x1b[0m` : s,
  yellow: s => hasColor ? `\x1b[33m${s}\x1b[0m` : s,
  cyan:   s => hasColor ? `\x1b[36m${s}\x1b[0m` : s,
  bold:   s => hasColor ? `\x1b[1m${s}\x1b[0m` : s,
  dim:    s => hasColor ? `\x1b[2m${s}\x1b[0m` : s,
}

function log(msg = '') { process.stderr.write(msg + '\n') }

function prompt(question) {
  const rl = readline.createInterface({ input: process.stdin, output: process.stderr })
  return new Promise(resolve => {
    rl.question(question, answer => {
      rl.close()
      resolve(answer.trim())
    })
  })
}

function ok()   { return c.green('[ok]') }
function fail() { return c.red('[fail]') }
function warn() { return c.yellow('[!]') }

// ── Credential storage ───────────────────────────────────────────────

function loadGlobalCreds() {
  try { return JSON.parse(fs.readFileSync(GLOBAL_CREDS_PATH, 'utf8')) }
  catch { return null }
}

function saveGlobalCreds(creds) {
  fs.mkdirSync(GLOBAL_CONFIG_DIR, { recursive: true })
  fs.writeFileSync(GLOBAL_CREDS_PATH, JSON.stringify(creds, null, 2) + '\n')
  try { fs.chmodSync(GLOBAL_CREDS_PATH, 0o600) } catch {}
}

function removeGlobalCreds() {
  try { fs.unlinkSync(GLOBAL_CREDS_PATH) } catch {}
}

function loadLocalConfig() {
  try { return JSON.parse(fs.readFileSync(LOCAL_CONFIG_PATH, 'utf8')) }
  catch { return null }
}

function saveLocalConfig(config) {
  fs.writeFileSync(LOCAL_CONFIG_PATH, JSON.stringify(config, null, 2) + '\n')
}

function isPlaceholder(key) {
  if (!key || key === 'YOUR_API_KEY_HERE') return true
  if (/\s/.test(key) || key.includes('...')) return true
  return false
}

/**
 * Resolve the current API key.
 * Priority: global creds > local config.json
 */
function resolveKey() {
  const creds = loadGlobalCreds()
  if (creds?.api_key && !isPlaceholder(creds.api_key)) {
    return { key: creds.api_key, source: '~/.config/skillboss/credentials.json', type: creds.type }
  }

  const config = loadLocalConfig()
  if (config?.apiKey && !isPlaceholder(config.apiKey)) {
    return { key: config.apiKey, source: 'config.json' }
  }

  return null
}

function maskKey(key) {
  if (!key || key.length < 14) return key
  return key.slice(0, 10) + '...' + key.slice(-4)
}

/**
 * Persist key to all credential stores.
 */
function persistKey(apiKey, type = 'permanent') {
  saveGlobalCreds({
    api_key: apiKey,
    type,
    updated_at: new Date().toISOString(),
  })
  log(`  ${ok()} Saved to ${c.dim('~/.config/skillboss/credentials.json')}`)

  const config = loadLocalConfig()
  if (config) {
    config.apiKey = apiKey
    saveLocalConfig(config)
    log(`  ${ok()} Updated ${c.dim('config.json')}`)
  }
}

function openBrowser(url) {
  try {
    if (process.platform === 'darwin')      execSync(`open "${url}"`, { stdio: 'ignore' })
    else if (process.platform === 'win32')  execSync(`start "" "${url}"`, { stdio: 'ignore' })
    else                                    execSync(`xdg-open "${url}"`, { stdio: 'ignore' })
    return true
  } catch { return false }
}

// ── Help text ─────────────────────────────────────────────────────────

function helpMain() {
  log('')
  log(`  ${c.bold('skillboss')} - CLI for the SkillBoss AI platform`)
  log('')
  log('  USAGE')
  log(`    skillboss ${c.dim('<command>')} ${c.dim('[subcommand]')} ${c.dim('[flags]')}`)
  log('')
  log('  COMMANDS')
  log(`    auth          Manage authentication with SkillBoss`)
  log(`    config        Manage configuration`)
  log(`    test          Test connection to SkillBoss API`)
  log(`    status        Show wallet balance and usage`)
  log('')
  log(`  Run ${c.cyan('skillboss <command> --help')} for more information about a command.`)
  log('')
}

function helpAuth() {
  log('')
  log(`  ${c.bold('skillboss auth')} - Manage authentication with SkillBoss`)
  log('')
  log('  COMMANDS')
  log(`    login         Sign in to a SkillBoss account ${c.dim('(opens browser)')}`)
  log(`    status        Show current authentication state`)
  log(`    logout        Remove stored credentials`)
  log(`    token         Output API key to stdout ${c.dim('(for scripting)')}`)
  log('')
  log(`  Run ${c.cyan('skillboss auth <command> --help')} for details.`)
  log('')
}

function helpAuthLogin() {
  log('')
  log(`  ${c.bold('skillboss auth login')} - Sign in to a SkillBoss account`)
  log('')
  log('  Sign in to SkillBoss via your browser to get a permanent API key.')
  log('  This is the recommended way to authenticate.')
  log('')
  log('  What happens:')
  log('    1. Your browser opens to skillboss.co')
  log('    2. You sign up or log in')
  log('    3. Copy your API key from the console')
  log('')
  log('  FLAGS')
  log(`    --help        Show this help`)
  log('')
  log('  EXAMPLES')
  log(`    ${c.dim('$')} skillboss auth login`)
  log('')
}

function helpAuthStatus() {
  log('')
  log(`  ${c.bold('skillboss auth status')} - Show current authentication state`)
  log('')
  log('  Displays the current API key, where it was loaded from,')
  log('  and your current balance.')
  log('')
  log('  EXAMPLES')
  log(`    ${c.dim('$')} skillboss auth status`)
  log('')
}

function helpAuthLogout() {
  log('')
  log(`  ${c.bold('skillboss auth logout')} - Remove stored credentials`)
  log('')
  log('  Removes the API key from all credential stores:')
  log('    - ~/.config/skillboss/credentials.json')
  log('    - config.json (reset to placeholder)')
  log('')
  log('  EXAMPLES')
  log(`    ${c.dim('$')} skillboss auth logout`)
  log('')
}

function helpAuthToken() {
  log('')
  log(`  ${c.bold('skillboss auth token')} - Output API key to stdout`)
  log('')
  log('  Prints the current API key to stdout.')
  log('  Designed for scripting and piping. Status messages go to stderr.')
  log('')
  log('  EXAMPLES')
  log(`    ${c.dim('$')} skillboss auth token`)
  log(`    ${c.dim('$')} curl -H "Authorization: Bearer $(skillboss auth token)" ...`)
  log('')
}

function helpConfig() {
  log('')
  log(`  ${c.bold('skillboss config')} - Manage configuration`)
  log('')
  log('  COMMANDS')
  log(`    set-key       Set your API key`)
  log(`    show          Show current configuration`)
  log('')
  log(`  Run ${c.cyan('skillboss config <command> --help')} for details.`)
  log('')
}

function helpConfigSetKey() {
  log('')
  log(`  ${c.bold('skillboss config set-key')} - Set your API key`)
  log('')
  log('  Saves your API key to ~/.config/skillboss/credentials.json')
  log('  The key is validated before saving.')
  log('')
  log('  USAGE')
  log(`    skillboss config set-key ${c.dim('<API_KEY>')}`)
  log('')
  log('  EXAMPLES')
  log(`    ${c.dim('$')} skillboss config set-key sk-abc123...`)
  log('')
}

function helpConfigShow() {
  log('')
  log(`  ${c.bold('skillboss config show')} - Show current configuration`)
  log('')
  log('  Displays the current API key (masked) and configuration file location.')
  log('')
  log('  EXAMPLES')
  log(`    ${c.dim('$')} skillboss config show`)
  log('')
}

function helpTest() {
  log('')
  log(`  ${c.bold('skillboss test')} - Test connection to SkillBoss API`)
  log('')
  log('  Validates your API key and tests connectivity.')
  log('')
  log('  EXAMPLES')
  log(`    ${c.dim('$')} skillboss test`)
  log('')
}

function helpStatusCmd() {
  log('')
  log(`  ${c.bold('skillboss status')} - Show wallet balance and usage`)
  log('')
  log('  Displays your wallet balance, recent usage, and auto top-up status.')
  log('')
  log('  EXAMPLES')
  log(`    ${c.dim('$')} skillboss status`)
  log('')
}

// ── Commands ──────────────────────────────────────────────────────────

async function cmdLogin(flags) {
  if (flags.includes('--help') || flags.includes('-h')) {
    helpAuthLogin()
    return
  }

  const current = resolveKey()

  log('')

  // Already has a key
  if (current) {
    log(`  ${ok()} Already signed in.`)
    log(`    Key:    ${maskKey(current.key)}`)
    log(`    Source: ${current.source}`)
    log('')
    log(`  Run ${c.cyan('skillboss auth status')} to see your balance.`)
    log('')
    return
  }

  // No key — open browser to sign up
  log(`  ${c.bold('Signing in to SkillBoss...')}`)
  log('')

  const loginUrl = `${WEB_BASE}/login`
  const opened = openBrowser(loginUrl)
  if (opened) {
    log(`  ${ok()} Opened ${c.cyan(WEB_BASE)} in your browser`)
  } else {
    log(`  ${warn()} Could not open browser. Open this URL manually:`)
  }
  log(`    ${c.dim(loginUrl)}`)
  log('')
  log(`  Sign up or log in, then copy your API key from the console.`)
  log('')

  const apiKey = await prompt(`  ? ${c.bold('Paste your API key:')} `)
  if (!apiKey || isPlaceholder(apiKey)) {
    log(`  ${fail()} No valid API key provided.`)
    log('')
    process.exit(1)
  }

  persistKey(apiKey, 'permanent')
  log('')
  log(`  ${c.bold(c.green("You're all set!"))}`)
  log('')
}

async function cmdStatus(flags) {
  if (flags.includes('--help') || flags.includes('-h')) {
    helpAuthStatus()
    return
  }

  const current = resolveKey()

  log('')

  if (!current) {
    log(`  ${warn()} Not logged in`)
    log(`  Run ${c.cyan('skillboss auth login')} to sign in.`)
    log('')
    return
  }

  log(`  ${ok()} Logged in`)
  log(`    Key:    ${maskKey(current.key)}`)
  log(`    Source: ${current.source}`)

  log('')
}

async function cmdLogout(flags) {
  if (flags.includes('--help') || flags.includes('-h')) {
    helpAuthLogout()
    return
  }

  const current = resolveKey()

  log('')

  if (!current) {
    log(`  ${c.dim('Not logged in.')}`)
    log('')
    return
  }

  const answer = await prompt(`  ? ${c.bold('Log out?')} Remove ${maskKey(current.key)} ${c.dim('[y/N]')} `)
  if (answer.toLowerCase() !== 'y') {
    log('  Cancelled.')
    log('')
    return
  }

  removeGlobalCreds()
  log(`  ${ok()} Removed ~/.config/skillboss/credentials.json`)

  const config = loadLocalConfig()
  if (config) {
    config.apiKey = 'YOUR_API_KEY_HERE'
    saveLocalConfig(config)
    log(`  ${ok()} Reset config.json`)
  }

  log('')
}

async function cmdToken(flags) {
  if (flags.includes('--help') || flags.includes('-h')) {
    helpAuthToken()
    return
  }

  const current = resolveKey()
  if (current) {
    process.stdout.write(current.key)
    return
  }

  process.stderr.write(`No API key found. Run: skillboss auth login\n`)
  process.exit(1)
}

// ── Config commands ───────────────────────────────────────────────────

async function cmdConfigSetKey(args) {
  const flags = args.filter(a => a.startsWith('-'))
  const apiKey = args.find(a => !a.startsWith('-'))

  if (flags.includes('--help') || flags.includes('-h') || !apiKey) {
    helpConfigSetKey()
    if (!apiKey) process.exit(1)
    return
  }

  log('')

  // Validate key format
  if (!apiKey.startsWith('sk-') || apiKey.length < 32) {
    log(`  ${fail()} Invalid API key format`)
    log(`    Keys must start with 'sk-' and be at least 32 characters`)
    log('')
    process.exit(1)
  }

  // Test the key by calling the API
  const s = spinner('Validating API key...')
  try {
    const resp = await fetch(`${API_BASE}/temp-token/poll-bind`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ temp_api_key: apiKey }),
    })

    if (!resp.ok && resp.status !== 404) {
      s.fail('API key validation failed')
      log(`    Status: ${resp.status}`)
      log('')
      process.exit(1)
    }

    s.stop('API key validated')
  } catch (err) {
    s.fail(`Network error: ${err.message}`)
    log('')
    process.exit(1)
  }

  // Save to credentials
  saveGlobalCreds({
    api_key: apiKey,
    type: 'permanent',
    updated_at: new Date().toISOString(),
  })
  log(`  ${ok()} Saved to ${c.dim(GLOBAL_CREDS_PATH)}`)

  // Update local config if it exists
  const config = loadLocalConfig()
  if (config) {
    config.apiKey = apiKey
    saveLocalConfig(config)
    log(`  ${ok()} Updated ${c.dim('config.json')}`)
  }

  log('')
  log(`  ${c.bold(c.green("API key configured successfully!"))}`)
  log(`  Run ${c.cyan('skillboss test')} to test your connection.`)
  log('')
}

async function cmdConfigShow(flags) {
  if (flags.includes('--help') || flags.includes('-h')) {
    helpConfigShow()
    return
  }

  const current = resolveKey()

  log('')

  if (!current) {
    log(`  ${warn()} No API key configured`)
    log(`  Run ${c.cyan('skillboss config set-key <KEY>')} to set your API key.`)
    log('')
    return
  }

  log(`  ${ok()} Configuration`)
  log(`    API Key: ${maskKey(current.key)}`)
  log(`    Source:  ${current.source}`)
  log(`    Type:    ${current.type || 'unknown'}`)
  log('')
}

// ── Test command ──────────────────────────────────────────────────────

async function cmdTest(flags) {
  if (flags.includes('--help') || flags.includes('-h')) {
    helpTest()
    return
  }

  const current = resolveKey()

  log('')

  if (!current) {
    log(`  ${fail()} No API key configured`)
    log(`  Run ${c.cyan('skillboss config set-key <KEY>')} to set your API key.`)
    log('')
    process.exit(1)
  }

  const s = spinner('Testing connection...')

  try {
    const resp = await fetch(`${API_BASE}/temp-token/poll-bind`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ temp_api_key: current.key }),
    })

    if (resp.ok || resp.status === 404) {
      s.stop('Connection successful')
      log(`  ${ok()} API key is valid`)
      log(`    Endpoint: ${API_BASE}`)
      log('')
    } else {
      s.fail('Connection failed')
      log(`  ${fail()} API returned status ${resp.status}`)
      log('')
      process.exit(1)
    }
  } catch (err) {
    s.fail('Connection failed')
    log(`  ${fail()} ${err.message}`)
    log('')
    process.exit(1)
  }
}

// ── Status command ────────────────────────────────────────────────────

async function cmdStatusCmd(flags) {
  if (flags.includes('--help') || flags.includes('-h')) {
    helpStatusCmd()
    return
  }

  const current = resolveKey()

  log('')

  if (!current) {
    log(`  ${fail()} No API key configured`)
    log(`  Run ${c.cyan('skillboss config set-key <KEY>')} to set your API key.`)
    log('')
    process.exit(1)
  }

  const s = spinner('Fetching account status...')

  try {
    // Try to get billing info from web API
    const resp = await fetch(`${WEB_BASE}/api/billing`, {
      method: 'GET',
      headers: {
        'Authorization': `Bearer ${current.key}`,
      },
    })

    if (resp.ok) {
      const data = await resp.json()
      s.stop('Account status')

      log(`  ${ok()} Wallet Balance: ${c.bold(c.green(`$${(data.wallet_balance_usd || 0).toFixed(2)}`))}`)

      if (data.auto_topup?.enabled) {
        log(`  ${ok()} Auto Top-Up: ${c.green('ON')} (${c.dim(`$${data.auto_topup.amount || 10} when < $${data.auto_topup.threshold || 3}`)}`)
      } else {
        log(`  ${warn()} Auto Top-Up: ${c.yellow('OFF')}`)
      }

      log('')
      log(`  Manage billing at: ${c.cyan(`${WEB_BASE}/console`)}`)
      log('')
    } else {
      s.fail('Failed to fetch status')
      log(`  ${warn()} Could not retrieve billing information`)
      log(`    Status: ${resp.status}`)
      log('')
      log(`  Your API key is valid, but billing data is unavailable.`)
      log(`  Visit ${c.cyan(`${WEB_BASE}/console`)} to view your account.`)
      log('')
    }
  } catch (err) {
    s.fail('Failed to fetch status')
    log(`  ${warn()} ${err.message}`)
    log('')
    log(`  Visit ${c.cyan(`${WEB_BASE}/console`)} to view your account.`)
    log('')
  }
}

// ── Main ──────────────────────────────────────────────────────────────

const args = process.argv.slice(2)
const command = args[0]
const subcommand = args[1]
const flags = args.slice(2)

async function main() {
  // skillboss --help
  if (!command || command === '--help' || command === '-h') {
    helpMain()
    process.exit(command ? 0 : 0)
  }

  if (command === 'auth') {
    // skillboss auth --help
    if (!subcommand || subcommand === '--help' || subcommand === '-h') {
      helpAuth()
      process.exit(subcommand ? 0 : 1)
    }

    switch (subcommand) {
      case 'login':   return cmdLogin(flags)
      case 'status':  return cmdStatus(flags)
      case 'logout':  return cmdLogout(flags)
      case 'token':   return cmdToken(flags)
      case 'resolve': return cmdToken(flags) // backward compat
      default:
        log('')
        log(`  ${c.red('Unknown command:')} auth ${subcommand}`)
        log(`  Run ${c.cyan('skillboss auth --help')} to see available commands.`)
        log('')
        process.exit(1)
    }
  }

  if (command === 'config') {
    // skillboss config --help
    if (!subcommand || subcommand === '--help' || subcommand === '-h') {
      helpConfig()
      process.exit(subcommand ? 0 : 1)
    }

    switch (subcommand) {
      case 'set-key': return cmdConfigSetKey(flags)
      case 'show':    return cmdConfigShow(flags)
      default:
        log('')
        log(`  ${c.red('Unknown command:')} config ${subcommand}`)
        log(`  Run ${c.cyan('skillboss config --help')} to see available commands.`)
        log('')
        process.exit(1)
    }
  }

  if (command === 'test') {
    return cmdTest(args.slice(1))
  }

  if (command === 'status') {
    return cmdStatusCmd(args.slice(1))
  }

  log('')
  log(`  ${c.red('Unknown command:')} ${command}`)
  log(`  Run ${c.cyan('skillboss --help')} to see available commands.`)
  log('')
  process.exit(1)
}

main().catch(err => {
  log(`\n  ${c.red('Error:')} ${err.message}\n`)
  process.exit(1)
})
